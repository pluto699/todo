{% extends 'document.tmpl' %}

{% import 'generate.tmpl' as generate with context %}

{% block includes %}
#include <bit>
#include <cstddef>
{% set types = [] %}
{% for contained_type in type.contained_types recursive %}
    {% if contained_type.token in ('enum', 'set', 'composite') and not contained_type.inplace %}
        {% set types = types.append(contained_type.name) %}
    {% endif %}
    {% if contained_type.token == 'composite' %}
        {{- loop(contained_type.contained_types) -}}
    {% endif %}
{% endfor %}
{% set types = types | sort | unique | list %}
{% if types | length > 0 %}

    {% for type in types %}
#include "{{ type | fmt_class_type | fmt_header_name }}"
    {% endfor %}
{% endif %}
{% endblock %}

{% block content %}

{{ generate.composite_decl(type) }}

{% endblock %}
