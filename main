struct MessagePrinter {
    template <typename FieldT>
        requires (requires { std::declval<FieldT>().value(); })
    static void print(std::ostream& os, FieldT field, std::string_view prefix = {}) {
        if (!prefix.empty()) {
            os << prefix << '.';
        }
        os << field.sbeRefName() << ": ";
        if (field.present()) {
            os << field.value();
        } else {
            os << "N/A";
        }
        os << '\n';
    }

    template <typename AggrT>
        requires (requires { typename AggrT::Fields; })
    static void print(std::ostream& os, AggrT aggr, std::string_view parent = {}) {
        std::string prefix{parent};
        if constexpr (requires { aggr.sbeRefName(); }) {
            prefix.append(".").append(aggr.sbeRefName());
        }

        [&]<template<typename...> typename L, typename... Ts>(L<Ts...>) {
            [&]<std::size_t... I>(std::index_sequence<I...>) {
                (MessagePrinter::print(os, aggr.template get<I>(), prefix), ...);
            }(std::make_index_sequence<sizeof...(Ts)>{});
        }(typename AggrT::Fields{});
    }
};

void test3() {
    using namespace b3::marketdata::umdf::sbe;

    std::array<std::byte, 64> buffer = {std::byte(0)};

    // auto sequenceReset = SequenceReset_1::wrapAndApplyHeader(buffer);
