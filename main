    // std::cout << "newSeqNo: " << sequenceReset.get<"newSeqNo">().value() << '\n';
    // std::cout << "---\n";

    MessagePrinter::print(std::cout, SequenceReset_1{buffer}, "SequenceReset_1");
    std::cout << "---\n";
    MessagePrinter::print(std::cout, SecurityStatus_3{buffer}, "SecurityStatus_3");
    std::cout << "---\n";
}

int main([[maybe_unused]] int argc, [[maybe_unused]] char* argv[]) {
    try {
        test3();
    } catch (std::exception const& e) {
        std::cerr << "ERROR: " << e.what() << '\n';
        return EXIT_FAILURE;
    }
    return EXIT_SUCCESS;
}
