{% macro set(type) %}
{% set class_cpp_t = type.name | fmt_class_name %}
{% set enc_cpp_t = type.encoding_type.name | replace_keyword %}
// name:            {{ type.name }}
// description:     {{ type.description }}
// since version:   {{ type.since_version }}
// deprecated:      {{ type.deprecated }}
// encoded length:  {{ type.encoded_length }}
class {{ class_cpp_t }} final {
private:
    {{ enc_cpp_t }} value_ = 0;

public:
{% for choice in type.choices %}
    static constexpr auto k{{ choice.name | upper_first }}Bit = {{ enc_cpp_t }}(1 << {{ choice.value }}u);
{% endfor %}

    constexpr {{ class_cpp_t }}() = default;

    constexpr {{ class_cpp_t }}({{ enc_cpp_t }} value) noexcept
        : value_{value}
    {}

    [[nodiscard]] constexpr auto rawValue() const noexcept -> {{ enc_cpp_t }} {
        return value_;
    }

    constexpr void setRawValue({{ enc_cpp_t }} value) noexcept {
        value_ = value;
    }

    constexpr {{ class_cpp_t }}& reset() noexcept {
        value_ = 0;
        return *this;
    }
{% for choice in type.choices %}
    {% set choice_bit = 'k' ~ choice.name | upper_first ~ 'Bit' %}

    [[nodiscard]] constexpr auto {{ choice.name | lower_first }}() noexcept -> bool {
        return {{ choice_bit }} == ({{ choice_bit }} & value_);
    }

    constexpr {{ class_cpp_t }}& {{ choice.name | lower_first }}(bool value) noexcept {
        value_ = value
            ? (value_ | {{ choice_bit }})
            : (value_ & ~{{ choice_bit }})
        ;
        return *this;
    }
{% endfor %}

template <typename CharT, typename Traits>
{% if type.inplace %}friend{% else %}inline{% endif %} std::basic_ostream<CharT, Traits>& operator<<(std::basic_ostream<CharT, Traits>& os, {{ class_cpp_t }} value) {
    // FIXME
    return os << "{{ class_cpp_t }}";
}
};

static_assert(sizeof({{ class_cpp_t }}) == {{ type.encoded_length }});
{%- endmacro %}

