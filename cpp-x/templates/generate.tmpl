// encoded length:  {{ type.encoded_length }}
class {{ class_cpp_t }}
{
private:
    std::byte* buffer_ = nullptr;
    {{ version_cpp_t }} actingVersion_ = 0;

public:
{% for contained_type in type.contained_types if contained_type.inplace %}
    {% if contained_type.token == 'enum' %}
    {{ enum(contained_type) | indent(4) }}

    {% elif contained_type.token == 'set' %}
    {{ set(contained_type) | indent(4) }}

    {% elif contained_type.token == 'composite' %}
    {{ composite(contained_type) | indent(4) }}

    {% endif %}
{% endfor %}
    constexpr {{ class_cpp_t }}() = default;

    constexpr {{ class_cpp_t }}(std::byte* buffer, {{ version_cpp_t }} actingVersion = sbeVersion()) noexcept
        : buffer_{buffer}
        , actingVersion_{actingVersion}
    {
    }

    [[nodiscard]] constexpr auto actingVersion() const noexcept -> {{ version_cpp_t }}
    {
        return actingVersion_;
    }

    [[nodiscard]] static constexpr auto sbeSchemaId() noexcept -> {{ schema_id_cpp_t }}
    {
        return {{ schema.id }};
    }

    [[nodiscard]] static constexpr auto sbeVersion() noexcept -> {{ version_cpp_t }}
    {
        return {{ schema.version }};
    }

    [[nodiscard]] static constexpr auto sbeEncodedLength() noexcept -> std::size_t
    {
        return {{ type.encoded_length }};
    }

    [[nodiscard]] static constexpr auto sbeName() noexcept -> char const* {
        return "{{ type.name }}";
    }
{% for contained_type in type.contained_types %}
    {% if contained_type.token == 'type' %}

    // type {{ contained_type.name }} {{ contained_type.length }}
    {{ field_ref_type(contained_type) | indent(4) }}
    {% elif contained_type.token == 'enum' %}

    // enum {{ contained_type.name }}
    {{ field_ref_enum(contained_type) | indent(4) }}
    {% elif contained_type.token == 'set' %}

    // set {{ contained_type.name }}
    {{ field_ref_set(contained_type) | indent(4) }}
    {% elif contained_type.token == 'composite' %}

    // composite {{ contained_type.name }}
    {{ field_ref_composite(contained_type) | indent(4) }}
    {% endif %}
{% endfor %}

    using Fields = MP_List<
{% for contained_type in type.contained_types %}
        {{ contained_type.reference_name | fmt_field_ref }}{% if not loop.last %},{% endif +%} // "{{ contained_type.reference_name }}"
{% endfor %}
    >;

    [[nodiscard]] static constexpr auto fieldsCount() noexcept -> std::size_t {
        return {{ type.contained_types | length }};
    }

    template <std::size_t I>
        requires (I < {{ type.contained_types | length }})
    constexpr auto get() const noexcept -> MP_At<Fields, MP_SizeT<I>> {
        return MP_At<Fields, MP_SizeT<I>>{buffer_, actingVersion_};
    }

    template <typename RefT>
        requires (MP_Find<Fields, MatchType<RefT>>::value < {{ type.contained_types | length }})
    constexpr auto get() const noexcept -> RefT {
        return RefT{buffer_, actingVersion_};
    }

    template <CtString N>
        requires (MP_Find<Fields, MatchSbeFieldName<N>>::value < {{ type.contained_types | length }})
    constexpr auto get() const noexcept -> MP_At<Fields, MP_Find<Fields, MatchSbeFieldName<N>>> {
        return MP_At<Fields, MP_Find<Fields, MatchSbeFieldName<N>>>{buffer_, actingVersion_};
