{% macro field_ref_type(entry) %}
{% set type = entry.type if entry.token == 'field' else entry %}
{% set field_name = entry.name if entry.token == 'field' else entry.reference_name %}
{% set field_ref_class_name = field_name | fmt_field_ref %}
{% set enc_cpp_t = type.primitive_type.name | replace_keyword %}
{% if type.length > 1 %}
    {% if type.primitive_type.name == 'char' %}
        {% set value_cpp_t = 'std::string_view' %}
    {% else %}
        {% set value_cpp_t = 'std::span<' ~ enc_cpp_t ~ ' const>' %}
    {% endif %}
{% else %}
    {% set value_cpp_t = enc_cpp_t %}
{% endif %}
struct {{ field_ref_class_name }} {
    // DEBUG: enc_cpp_t -> {{ enc_cpp_t }}
    // DEBUG: value_cpp_t -> {{ value_cpp_t }}
    // DEBUG: encoded_length -> {{ type.encoded_length }}

    using value_type = {{ value_cpp_t }};
{% if entry.presence == 'required' or entry.presence == 'optional' %}

    std::byte* buffer = nullptr;

    {# constructor (required, optional) #}
    constexpr {{ field_ref_class_name }}(std::byte* blockBuffer, [[maybe_unused]] {{ version_cpp_t }} actingVersion = {{ schema.version }}) noexcept
        : buffer{blockBuffer + {{ entry.offset }}}
    {}
{% elif entry.presence == 'constant' %}

    {# constructor (constant) #}
    constexpr {{ field_ref_class_name }}([[maybe_unused]] std::byte* blockBuffer, [[maybe_unused]] {{ version_cpp_t }} actingVersion = {{ schema.version }}) noexcept
    {}
{% endif %}

    [[nodiscard]] static constexpr auto sbeFieldName() noexcept -> char const* {
        return "{{ field_name }}";
    }

    [[nodiscard]] static constexpr auto sbePresence() noexcept -> char const* {
        return "{{ entry.presence }}";
    }

    [[nodiscard]] static constexpr auto sbeLength() noexcept -> std::size_t {
        return {{ type.length }};
    }

    [[nodiscard]] static constexpr auto sbeSinceVersion() noexcept -> {{ version_cpp_t }} {
        return {{ entry.since_version }};
    }
{% if entry.character_encoding %}

    {# characterEncoding if present #}
    [[nodiscard]] static constexpr auto sbeCharacterEncoding() noexcept -> char const* {
        return "{{ type.character_encoding }}";
    }
{% endif %}

    [[nodiscard]] static constexpr auto nullValue() noexcept -> {{ enc_cpp_t }} {
        return {{ type.null_value | replace_keyword }};
    }

    [[nodiscard]] static constexpr auto minValue() noexcept -> {{ enc_cpp_t }} {
        return {{ type.min_value | replace_keyword }};
    }

    [[nodiscard]] static constexpr auto maxValue() noexcept -> {{ enc_cpp_t }} {
        return {{ type.max_value | replace_keyword }};
    }
{% if entry.presence == 'required' or entry.presence == 'optional' %}

    {# data() #}
    [[nodiscard]] constexpr auto data() const noexcept -> {{ enc_cpp_t }} const* {
        return std::bit_cast<{{ enc_cpp_t }} const*>(buffer);
    }

    {# data() #}
    [[nodiscard]] constexpr auto data() noexcept -> {{ enc_cpp_t }}* {
        return std::bit_cast<{{ enc_cpp_t }}*>(buffer);
    }

    {# data0() #}
    // First byte-swapped item of data()
    [[nodiscard]] constexpr auto data0() const noexcept -> {{ enc_cpp_t }} {
    {% if type.primitive_type.size != 1 %}
        auto val = this->data()[0];
        swapByteOrder(val);
        return val;
    {% else %}
        return this->data()[0];
    {% endif %}
    }
{% elif entry.presence == 'constant' %}

    {# data() #}
    [[nodiscard]] constexpr auto data() const noexcept -> {{ enc_cpp_t }} const* {
    {% if type.primitive_type.name == 'char' and type.length == 1 %}
        static constexpr auto storage = '{{ type.const_value }}';
        return &storage;
    {% elif type.primitive_type.name == 'char' and type.length > 1 %}
        static constexpr auto storage = std::string_view("{{ type.const_value }}");
        return storage.data();
    {% elif type.length == 1 %}
        static constexpr auto storage = {{ enc_cpp_t }}({{ type.const_value }});
        return &storage;
    {% elif type.length > 1 %}
        static_assert(false, "not implemented for encoding '{{ type.const_value }}'");
    {% endif %}
    }
{% endif %}
{% if entry.presence == 'required' or entry.presence == 'constant' %}

    {# present() #}
    [[nodiscard]] static constexpr auto present() noexcept -> bool {
        return true;
    }
{% elif entry.presence == 'optional' %}

    {# present() #}
    [[nodiscard]] constexpr auto present() const noexcept -> bool {
    {% if type.primitive_type.name == 'float' and type.null_value == 'FLOAT_NULL' %}
        return !std::isnan(this->data0());
    {% elif type.primitive_type.name == 'double' and type.null_value == 'DOUBLE_NULL' %}
        return !std::isnan(*this->data0());
    {% else %}
        return this->data0() != this->nullValue();
    {% endif %}
    }
{% endif %}

    {# absent() #}
    [[nodiscard]] constexpr auto absent() const noexcept -> bool {
        return !this->present();
    }
{% if (entry.presence == 'required' or entry.presence == 'optional') and type.length == 1 %}

    {# value() #}
    [[nodiscard]] constexpr auto value() const noexcept -> {{ value_cpp_t }} {
        return this->data0();
    }
{% elif (entry.presence == 'required' or entry.presence == 'optional') and type.primitive_type.name == 'char' and type.length > 1 %}

    {# value() #}
    [[nodiscard]] constexpr auto value() const noexcept -> {{ value_cpp_t }} {
        auto const ptr = this->data();
        std::size_t length = 0;
        for (; length < {{ type.length }} && *(ptr + length) != '\0'; ++length) {}
        return {{ value_cpp_t }}{ptr, length};
    }
{% elif (entry.presence == 'required' or entry.presence == 'optional') and type.length > 1 %}

    {# value() #}
    [[nodiscard]] constexpr auto value() const noexcept -> {{ value_cpp_t }} {
        return {{ value_cpp_t }}{this->data(), {{ type.length }}};
    }
{% elif entry.presence == 'constant' and type.length == 1 %}

    {# value() #}
    [[nodiscard]] constexpr auto value() const noexcept -> {{ value_cpp_t }} {
        return *this->data();
    }
{% elif entry.presence == 'constant' and type.length > 1 %}

    {# value() #}
    [[nodiscard]] constexpr auto value() const noexcept -> {{ value_cpp_t }} {
        return {{ value_cpp_t }}{this->data(), {{ type.length }}};
    }
{% endif %}
{% if (entry.presence == 'required' or entry.presence == 'optional') and type.length == 1 %}

    {# value(val) #}
    constexpr auto value({{ value_cpp_t }} val) noexcept -> {{ field_ref_class_name }}& {
    {% if type.primitive_type.size != 1 %}
        swapByteOrder(val);
    {% endif %}
        *this->data() = val;
        return *this;
    }
{% elif (entry.presence == 'required' or entry.presence == 'optional') and type.primitive_type.name == 'char' and type.length > 1 %}

    {# value(val) #}
    constexpr auto value({{ value_cpp_t }} val) -> {{ field_ref_class_name }}& {
        if (val.size() > {{ type.length }}) [[unlikely]] {
            throw std::runtime_error{"text too long to encode (\"{{ field_ref_class_name }}\")"};
        }
        std::copy_n(val.data(), val.size(), this->data());
        if (val.size() < {{ type.length }}) {
            this->data()[val.size()] = '\0';
        }
        return *this;
    }
{% elif (entry.presence == 'required' or entry.presence == 'optional') and type.length > 1 %}

    {# value(val) #}
    constexpr auto value({{ value_cpp_t }} val) -> {{ field_ref_class_name }}& {
        if (val.size() != {{ type.length }}) [[unlikely]] {
            throw std::runtime_error{"unexpected data length to encode (\"{{ field_ref_class_name }}\")"};
        }
        std::copy_n(val.data(), val.size(), this->data());
        return *this;
    }
{% endif %}
{% if entry.presence == 'optional' %}

    {# reset() #}
    constexpr auto reset() noexcept -> {{ field_ref_class_name }}& {
        *this->data() = *this->nullValue();
        return *this;
    }
{% endif %}
};
{%- endmacro %}

