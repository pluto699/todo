{% macro enum(type) %}
{% set class_cpp_t = type.name | fmt_class_name %}
{% set enc_cpp_t = type.encoding_type.name | replace_keyword %}
// name:            {{ type.name }}
// description:     {{ type.description }}
// since version:   {{ type.since_version }}
// deprecated:      {{ type.deprecated }}
// encoded length:  {{ type.encoded_length }}
enum class {{ class_cpp_t }} : {{ enc_cpp_t }} {
{% for entry in type.valid_values %}
    {% if type.encoding_type.name == 'char' %}
    {{ entry.name }} = '{{ entry.value }}',
    {% else %}
    {{ entry.name }} = {{ entry.value }},
    {% endif %}
{% endfor %}
    SBE_NULL = {{ type.null_value | replace_keyword }},
};

template <typename CharT, typename Traits>
{% if type.inplace %}friend{% else %}inline{% endif %} std::basic_ostream<CharT, Traits>& operator<<(std::basic_ostream<CharT, Traits>& os, {{ class_cpp_t }} value) {
    switch (value) {
    {% for entry in type.valid_values %}
    case {{ class_cpp_t }}::{{ entry.name }}: os << "{{ entry.name }}"; break;
    {% endfor %}
    case {{ class_cpp_t }}::SBE_NULL: os << "NULL"; break;
    default: os << "INVALID(" << (int)static_cast<{{ enc_cpp_t }}>(value) << ")"; break;
    }
    return os;
}

static_assert(sizeof({{ class_cpp_t }}) == {{ type.encoded_length }});
{%- endmacro %}

